# VoiceMedAI — copy to .env and adjust

# ── ASR ────────────────────────────────────────────────────────────
VOICEMED_ASR_MODE=whisper
WHISPER_MODEL_SIZE=small           # local fallback model (Groq is primary)

# ── Cloud AI providers ─────────────────────────────────────────────
GROQ_API_KEY=                      # ASR (whisper-large-v3-turbo) + LLM (llama-3.1-8b)
GEMINI_API_KEY=                    # optional LLM fallback

# ── Auth ───────────────────────────────────────────────────────────
JWT_SECRET=                        # generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_TTL_HOURS=24
GOOGLE_CLIENT_ID=                  # Google Identity Services OAuth client (optional)

# ── Database ───────────────────────────────────────────────────────
# Leave unset for local SQLite (data/voicemed.db). For Supabase/Postgres use
# the SESSION POOLER url (IPv4) — the direct db.*.supabase.co host is IPv6-only:
# DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Security / CORS ────────────────────────────────────────────────
# Comma-separated frontend origins allowed by CORS. REQUIRED in production.
# FRONTEND_ORIGINS=https://your-frontend.vercel.app

# ── Server ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
